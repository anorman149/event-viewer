# Copy this file to docker-compose.env to override local dev defaults.
# docker-compose.env is gitignored — never commit real secrets.
#
# NOTE: docker-compose.yml ships safe defaults for every variable so
# `docker compose up -d` works immediately without this file.
# Copy and customise only when you need non-default values.

# PostgreSQL password for the eventviewer database user.
POSTGRES_PASSWORD=changeme-local

# Kafka KRaft cluster ID — must be a 22-character URL-safe base64 string.
# Generate a new one: docker run --rm apache/kafka:3.8 kafka-storage.sh random-uuid
CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qg

# Dev RSA private key path — used by scripts/generate-dev-jwt.sh for manual testing.
# Generate the key pair:
#   openssl genrsa -out dev-private.pem 2048
#   openssl rsa -in dev-private.pem -pubout -out platform-public.pem
# Then copy platform-public.pem to each app's src/main/resources/keys/.
DEV_PRIVATE_KEY_PATH=./dev-private.pem
